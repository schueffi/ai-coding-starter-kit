# Supabase — VoteBoard project
# Copy this file to .env.local and fill in your values.
# Get these from: https://supabase.com/dashboard/project/<your-project-id>/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# E2E test credentials — a pre-existing, email-verified account in Supabase
# If not set, authenticated E2E tests are skipped (unauthenticated tests still run)
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=testpassword123
